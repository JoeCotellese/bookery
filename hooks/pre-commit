#!/usr/bin/env bash
# ABOUTME: Pre-commit hook that runs ruff and pyright on staged Python files.
# ABOUTME: Blocks commit if either tool reports errors.

set -euo pipefail

# Get staged Python files (added, copied, modified, renamed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.py')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FAILED=0

echo "pre-commit: ruff check..."
if ! uv run ruff check $STAGED_FILES; then
    FAILED=1
fi

echo "pre-commit: pyright..."
if ! uv run pyright $STAGED_FILES; then
    FAILED=1
fi

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "pre-commit: ❌ Fix errors above before committing."
    exit 1
fi

echo "pre-commit: ✓ All checks passed."
