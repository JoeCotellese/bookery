/* Two-pane layout for Bookery TUI */
/* Left pane: book list, Right pane: book detail */

Horizontal {
    height: 1fr;
}

#book-list {
    width: 2fr;
    border: solid $panel;
}

#book-list:focus-within {
    border: solid $accent;
}

#book-table {
    height: 1fr;
}

#row-count {
    height: 1;
    dock: bottom;
    text-style: dim;
    padding: 0 2;
}

#book-detail {
    width: 3fr;
    border: solid $panel;
    padding: 1 2;
}

#book-detail:focus-within {
    border: solid $accent;
}

#detail-header {
    text-style: bold;
    padding: 0 0 1 0;
}

#detail-metadata {
    padding: 0 0 1 0;
}

#detail-scroll {
    height: 1fr;
}
